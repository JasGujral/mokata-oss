.DS_Store
*.log
.env

# Claude Code local settings (machine-specific; should not be committed)
.claude/

# Python build/cache artifacts
__pycache__/
*.pyc
*.egg-info/

# Local helper script (one-off; not part of the framework)
push-to-github.command

# MkDocs build output
site/
uv.lock

# The Complete Guide PDF is generated from its markdown in CI (single source, no drift);
# never commit a static render (it would drift from the page).
docs/tutorials/mokata-complete-guide.pdf

# Runtime artifact: mokata creates .mokata/ at a repo root when run there (tests/commands).
# The framework source repo is not itself a mokata project, so never track it.
.mokata/
# Release script backups (scripts/release-*.sh) — local safety copies, not source.
release-backup-*/

# Marketing / brand assets — kept local, not shipped with the OSS code or a hotfix.
# (Publish deliberately as a separate step if/when desired.)
docs/marketing/
mokata-ad-features.md

# Large launch/marketing media — hosted elsewhere (or Git LFS), never in git history.
mokata_ad_60s_memory_vertical.mp4
docs/launch/assets/
