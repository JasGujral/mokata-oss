{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mokata stack manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "mokata",
    "profile",
    "capabilities",
    "tools"
  ],
  "additionalProperties": true,
  "properties": {
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "mokata": {
      "type": "object",
      "required": [
        "version"
      ],
      "properties": {
        "version": {
          "type": "string"
        }
      }
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "settings": {
      "type": "object"
    },
    "layers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "enabled"
        ]
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "fallback"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "layer": {
            "type": "string"
          },
          "fallback": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "provides",
          "kind",
          "detect"
        ],
        "properties": {
          "provides": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "mcp",
              "cli",
              "library",
              "builtin",
              "external"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "detect": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "enum": [
                  "command",
                  "python_module",
                  "path",
                  "always"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
