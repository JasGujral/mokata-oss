{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mokata-hook session-start --plugin-root \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mokata-hook secret-guard"
          }
        ]
      }
    ]
  }
}
